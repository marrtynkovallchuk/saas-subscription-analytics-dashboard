SELECT
  plan_tier,
  COUNT(DISTINCT account_id) AS total_accounts,
  COUNT(DISTINCT CASE WHEN end_date IS NOT NULL THEN account_id END) AS canceled_accounts,
  ROUND(
    AVG(DATE_DIFF(end_date, start_date, DAY)), 2
  ) AS avg_days_to_cancel,
  MIN(DATE_DIFF(end_date, start_date, DAY)) AS min_days_to_cancel,
  MAX(DATE_DIFF(end_date, start_date, DAY)) AS max_days_to_cancel
FROM `Saas.ravenstack_subscriptions`
WHERE end_date IS NOT NULL  
GROUP BY plan_tier
ORDER BY avg_days_to_cancel ASC;
